---
import { siteUrl } from '../utils/url';

const navItems = [
  { label: 'Ateliers', href: siteUrl('/ateliers/') },
  { label: 'Cours', href: siteUrl('/cours/') },
  { label: 'Doc', href: siteUrl('/doc/') },
  { label: 'Blog', href: siteUrl('/blog/') },
  { label: 'Boutique', href: siteUrl('/boutique/') },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-base-200/60 bg-base-100/80 backdrop-blur-xl">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href={siteUrl('/')} class="flex items-center gap-3 group">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center pulse-glow">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
            <circle cx="12" cy="3" r="1"/>
          </svg>
        </div>
        <div>
          <span class="font-bold text-base-content text-sm leading-tight">Fablab</span>
          <span class="block text-xs text-base-content/50 leading-tight font-mono">ESP32 · Ardèche</span>
        </div>
      </a>

      <!-- Navigation desktop -->
      <div class="hidden md:flex items-center gap-1">
        {navItems.map(item => (
          <a
            href={item.href}
            class={`px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 ${
              currentPath.includes(item.label.toLowerCase())
                ? 'bg-primary/15 text-primary'
                : 'text-base-content/70 hover:text-base-content hover:bg-base-200/60'
            }`}
          >
            {item.label}
          </a>
        ))}
      </div>

      <!-- Actions droite -->
      <div class="flex items-center gap-3">
        <!-- Toggle dark/light -->
        <button
          id="theme-toggle"
          class="btn btn-ghost btn-sm btn-circle"
          aria-label="Changer le thème"
        >
          <svg id="icon-moon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
          </svg>
          <svg id="icon-sun" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
        </button>

        <!-- CTA atelier -->
        <a href={siteUrl('/ateliers/')} class="hidden sm:flex btn btn-primary btn-sm gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
          Rejoindre un atelier
        </a>

        <!-- Menu mobile -->
        <div class="md:hidden dropdown dropdown-end">
          <button tabindex="0" class="btn btn-ghost btn-sm btn-square" aria-label="Menu">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
          <ul tabindex="0" class="dropdown-content menu bg-base-200 rounded-xl shadow-xl w-52 p-2 mt-2 border border-base-300">
            {navItems.map(item => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
            <li class="mt-2">
              <a href={siteUrl('/ateliers/')} class="btn btn-primary btn-sm justify-start">
                Rejoindre un atelier
              </a>
            </li>
          </ul>
        </div>
      </div>

    </div>
  </nav>
</header>

<script is:inline>
  const toggle = document.getElementById('theme-toggle');
  const moon = document.getElementById('icon-moon');
  const sun = document.getElementById('icon-sun');
  const html = document.documentElement;

  function updateIcons() {
    const theme = html.getAttribute('data-theme');
    if (theme === 'light') {
      moon.classList.add('hidden');
      sun.classList.remove('hidden');
    } else {
      moon.classList.remove('hidden');
      sun.classList.add('hidden');
    }
  }

  updateIcons();

  toggle.addEventListener('click', () => {
    const current = html.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    updateIcons();
  });
</script>
