---
// GitHubCodeBlock — Affiche du code depuis GitHub avec coloration Shiki
// Usage: <GitHubCodeBlock repo="user/repo" file="path/to/file.py" language="python" title="..." />

export interface Props {
  repo: string;
  file: string;
  language?: string;
  title?: string;
  startLine?: number;
  endLine?: number;
}

const { repo, file, language = 'python', title, startLine, endLine } = Astro.props;

const rawUrl = `https://raw.githubusercontent.com/${repo}/main/${file}`;
const githubUrl = `https://github.com/${repo}/blob/main/${file}`;

let code = '';
let error = '';

try {
  const res = await fetch(rawUrl);
  if (res.ok) {
    const fullCode = await res.text();
    if (startLine || endLine) {
      const lines = fullCode.split('\n');
      const start = (startLine || 1) - 1;
      const end = endLine || lines.length;
      code = lines.slice(start, end).join('\n');
    } else {
      code = fullCode;
    }
  } else {
    error = `Impossible de charger le fichier (HTTP ${res.status})`;
    code = `# Fichier : ${file}\n# Repo : ${repo}\n# Le fichier sera disponible une fois le repo créé sur GitHub.`;
  }
} catch (e) {
  error = 'Erreur de connexion à GitHub';
  code = `# Fichier : ${file}\n# Repo : ${repo}\n# Le fichier sera disponible une fois le repo créé sur GitHub.`;
}

// Coloration syntaxique avec Shiki
import { codeToHtml } from 'shiki';

const highlighted = await codeToHtml(code, {
  lang: language,
  themes: {
    light: 'github-light',
    dark: 'tokyo-night',
  },
  defaultColor: false,
});

const displayTitle = title || file.split('/').pop() || file;
const lineCount = code.split('\n').length;
---

<details class="code-block rounded-2xl overflow-hidden border border-base-200/60 my-6">

  <!-- En-tête cliquable -->
  <summary class="code-header flex items-center justify-between px-4 py-3 cursor-pointer select-none list-none">
    <div class="flex items-center gap-3 min-w-0">
      <!-- Flèche dépliable -->
      <svg class="code-chevron w-4 h-4 code-dim flex-shrink-0 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>

      <!-- Titre + fichier -->
      <div class="min-w-0">
        <div class="flex items-center gap-2">
          <span class="code-title text-sm font-medium truncate">{displayTitle}</span>
          <span class="code-dim text-xs font-mono flex-shrink-0">.{language}</span>
        </div>
        <div class="code-dim text-xs font-mono truncate">{file}</div>
      </div>
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-2 flex-shrink-0">
      <span class="code-dim text-xs font-mono">{lineCount} lignes</span>

      <!-- Bouton Copier -->
      <button
        class="copy-btn flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg code-btn text-xs font-medium transition-all"
        data-code={code}
        title="Copier le code"
      >
        <svg class="copy-icon w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
        </svg>
        <svg class="check-icon w-3.5 h-3.5 hidden text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        <span class="copy-label">Copier</span>
      </button>

      <!-- Bouton GitHub -->
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg code-btn text-xs font-medium transition-all"
        title="Voir sur GitHub"
      >
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
      </a>
    </div>
  </summary>

  <!-- Avertissement si erreur de chargement -->
  {error && (
    <div class="px-4 py-2 bg-yellow-500/10 border-b border-yellow-500/20 text-yellow-400/80 text-xs flex items-center gap-2">
      <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.961-.833-2.731 0L3.102 16.5c-.77.833.192 2.5 1.732 2.5z"/>
      </svg>
      {error} — le contenu ci-dessous est un placeholder
    </div>
  )}

  <!-- Code coloré (visible quand déplié) -->
  <div class="overflow-x-auto">
    <div class="code-content text-sm" set:html={highlighted} />
  </div>

</details>

<style>
  /* --- Thème sombre (défaut) --- */
  .code-block { background: #1a1b26; }
  .code-header { border-color: rgba(255,255,255,0.08); background: rgba(255,255,255,0.03); }
  .code-title { color: rgba(255,255,255,0.8); }
  .code-dim { color: rgba(255,255,255,0.3); }
  .code-btn { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.6); }
  .code-btn:hover { background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.9); }

  .code-content :global(.shiki) { background: transparent !important; }
  .code-content :global(pre) { margin: 0 !important; border-radius: 0 !important; border: none !important; background: transparent !important; padding: 1.25rem 1.5rem !important; }
  .code-content :global(code) { font-size: 0.825rem !important; line-height: 1.7 !important; }

  /* Shiki dual themes : appliquer les couleurs dark par défaut */
  .code-content :global(span) { color: var(--shiki-dark) !important; }

  /* --- Thème clair --- */
  :global([data-theme="light"]) .code-block { background: #f6f8fa; }
  :global([data-theme="light"]) .code-header { border-color: rgba(0,0,0,0.08); background: rgba(0,0,0,0.03); }
  :global([data-theme="light"]) .code-title { color: rgba(0,0,0,0.8); }
  :global([data-theme="light"]) .code-dim { color: rgba(0,0,0,0.4); }
  :global([data-theme="light"]) .code-btn { background: rgba(0,0,0,0.06); color: rgba(0,0,0,0.5); }
  :global([data-theme="light"]) .code-btn:hover { background: rgba(0,0,0,0.1); color: rgba(0,0,0,0.8); }

  /* Shiki dual themes : appliquer les couleurs light */
  :global([data-theme="light"]) .code-content :global(span) { color: var(--shiki-light) !important; }

  /* Flèche qui tourne quand ouvert */
  .code-block summary::-webkit-details-marker { display: none; }
  .code-block[open] .code-chevron { transform: rotate(90deg); }
  .code-header:hover { opacity: 0.85; }
</style>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const code = btn.getAttribute('data-code') || '';
      const copyIcon = btn.querySelector('.copy-icon');
      const checkIcon = btn.querySelector('.check-icon');
      const label = btn.querySelector('.copy-label');

      try {
        await navigator.clipboard.writeText(code);
        copyIcon?.classList.add('hidden');
        checkIcon?.classList.remove('hidden');
        if (label) label.textContent = 'Copié !';

        setTimeout(() => {
          copyIcon?.classList.remove('hidden');
          checkIcon?.classList.add('hidden');
          if (label) label.textContent = 'Copier';
        }, 2000);
      } catch {
        console.error('Impossible de copier');
      }
    });
  });
</script>
