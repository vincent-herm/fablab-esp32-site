---
import DifficultyBadge from './DifficultyBadge.astro';

export interface Props {
  title: string;
  description: string;
  href: string;
  level: 'debutant' | 'intermediaire' | 'avance';
  duration: string;
  tags?: string[];
  image?: string;
  numero?: number;
}

const { title, description, href, level, duration, tags = [], image, numero } = Astro.props;
---

<a href={href} class="group block card-hover">
  <div class="rounded-2xl border border-base-200/80 bg-base-200/30 overflow-hidden hover:border-primary/30 transition-colors duration-300">

    <!-- Image / Placeholder -->
    <div class="relative h-44 bg-gradient-to-br from-blue-500/10 to-purple-600/10 overflow-hidden">
      {image ? (
        <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
      ) : (
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="text-6xl font-black font-mono text-base-content/5 select-none">
            {numero !== undefined ? (numero < 10 ? `0${numero}` : `${numero}`) : '??'}
          </div>
          <!-- Motif circuit -->
          <svg class="absolute inset-0 w-full h-full opacity-5" viewBox="0 0 100 100" preserveAspectRatio="none">
            <line x1="10" y1="50" x2="90" y2="50" stroke="currentColor" stroke-width="0.5"/>
            <line x1="50" y1="10" x2="50" y2="90" stroke="currentColor" stroke-width="0.5"/>
            <circle cx="50" cy="50" r="5" fill="none" stroke="currentColor" stroke-width="0.5"/>
            <circle cx="10" cy="50" r="3" fill="currentColor" opacity="0.5"/>
            <circle cx="90" cy="50" r="3" fill="currentColor" opacity="0.5"/>
            <circle cx="50" cy="10" r="3" fill="currentColor" opacity="0.5"/>
            <circle cx="50" cy="90" r="3" fill="currentColor" opacity="0.5"/>
          </svg>
        </div>
      )}

      <!-- Numéro de l'atelier -->
      {numero !== undefined && (
        <div class="absolute top-3 left-3 bg-base-100/80 backdrop-blur-sm rounded-lg px-2.5 py-1 text-xs font-bold font-mono text-base-content/60">
          {numero === 0 ? 'DÉCOUVERTE' : `ATELIER ${numero < 10 ? `0${numero}` : numero}`}
        </div>
      )}
    </div>

    <!-- Contenu -->
    <div class="p-5">
      <div class="flex items-start justify-between gap-3 mb-3">
        <h3 class="font-bold text-base-content group-hover:text-primary transition-colors leading-tight">
          {title}
        </h3>
        <svg class="w-4 h-4 text-base-content/30 group-hover:text-primary group-hover:translate-x-1 transition-all flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </div>

      <p class="text-sm text-base-content/60 leading-relaxed mb-4 line-clamp-2">
        {description}
      </p>

      <!-- Meta -->
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2 flex-wrap">
          <DifficultyBadge level={level} size="sm" />
          <span class="inline-flex items-center gap-1 text-xs text-base-content/50">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            {duration}
          </span>
        </div>
      </div>

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-3 pt-3 border-t border-base-200/60">
          {tags.map(tag => (
            <span class="text-xs px-2 py-0.5 rounded-md bg-base-300/60 text-base-content/50 font-mono">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </div>
</a>
