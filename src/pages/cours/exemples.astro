                  <!-- Titre de sous-section -->
                  <h3 class="text-base font-bold mb-3 flex items-center gap-2">
                    <span class={`w-6 h-6 rounded-full flex items-center justify-center text-xs font-black shrink-0 ${colorMap[cat.color]}`}>{idx + 1}</span>
                    {sub.titre}
                  </h3>

                  <!-- Théorie -->
                  <div class={`rounded-xl border p-5 mb-4 text-sm text-base-content/75 leading-relaxed ${theorieBorderMap[cat.color]}`}>
                    <Fragment set:html={sub.theorie} />
                  </div>

                  <!-- Exemples -->
                  {sub.exemples.length > 0 && (
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2.5">
                      {sub.exemples.map(ex => (
                        <a
                          href={`${BASE_RAW}/${cat.slug}/${ex.fichier}`}
                          target="_blank"
                          class={`group flex items-center gap-3 rounded-xl border p-3.5 hover:bg-base-200/40 transition-colors ${colorMap[cat.color]}`}
                        >
                          <span class="text-xs font-mono font-bold opacity-60 shrink-0">py</span>
                          <div class="min-w-0">
                            <div class="text-xs font-mono font-medium truncate">{ex.fichier}</div>
                            <div class="text-xs text-base-content/50 mt-0.5">{ex.desc}</div>
                          </div>
                          <svg class="w-3.5 h-3.5 shrink-0 opacity-30 group-hover:opacity-70 transition-opacity ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
