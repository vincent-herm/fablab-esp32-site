---
import Layout from '../../layouts/Layout.astro';
import AtelierCard from '../../components/AtelierCard.astro';
import { siteUrl } from '../../utils/url';

const ateliers = [
  {
    numero: 0,
    title: 'Initiation — Zéro câblage',
    description: '10 manipulations pour découvrir l\'ESP32 : REPL, LED, PWM, bouton, WiFi, serveur web. Rien à brancher.',
    href: siteUrl('/ateliers/initiation/'),
    level: 'debutant' as const,
    duration: '3h',
    tags: ['ESP32', 'MicroPython', 'WiFi', 'LED', 'Débutant'],
  },
  {
    numero: 1,
    title: 'Serveur web avec ESP32',
    description: 'Crée un point d\'accès WiFi, sers une page HTML et contrôle une LED depuis ton navigateur.',
    href: siteUrl('/ateliers/serveur-web-esp32/'),
    level: 'debutant' as const,
    duration: '3h',
    tags: ['ESP32', 'WiFi', 'MicroPython', 'HTML', 'LED'],
  },
  {
    numero: 2,
    title: 'LED RGB et NeoPixel',
    description: 'Anime un bandeau de LED RGB WS2812 : couleurs, défilement, arc-en-ciel et effets aléatoires.',
    href: siteUrl('/ateliers/neopixel/'),
    level: 'debutant' as const,
    duration: '3h',
    tags: ['ESP32', 'NeoPixel', 'WS2812', 'RGB', 'Animations'],
  },
  {
    numero: 3,
    title: 'Station météo',
    description: 'Mesure la température avec un DS18B20 et affiche les données sur un écran OLED SSD1306.',
    href: siteUrl('/ateliers/station-meteo/'),
    level: 'debutant' as const,
    duration: '3h',
    tags: ['ESP32', 'DS18B20', 'OLED', 'I2C', '1-Wire'],
  },
  {
    numero: 4,
    title: 'Lumière automatique',
    description: 'Une cellule LDR détecte l\'obscurité et allume une LED en PWM — plus il fait sombre, plus c\'est lumineux.',
    href: siteUrl('/ateliers/lumiere-auto/'),
    level: 'debutant' as const,
    duration: '3h',
    tags: ['ESP32', 'ADC', 'PWM', 'LDR', 'Automatisme'],
  },
  {
    numero: 5,
    title: 'Clavier musical',
    description: '4 boutons jouent des notes sur un buzzer. Mode libre ou mélodie automatique — Frère Jacques inclus !',
    href: siteUrl('/ateliers/clavier-musical/'),
    level: 'debutant' as const,
    duration: '3h',
    tags: ['ESP32', 'PWM', 'Buzzer', 'Musique', 'Boutons'],
  },
  {
    numero: 6,
    title: 'Mesure de distance',
    description: 'Le capteur ultrason HC-SR04 mesure la distance et affiche une barre de progression sur l\'OLED.',
    href: siteUrl('/ateliers/distance/'),
    level: 'intermediaire' as const,
    duration: '3h',
    tags: ['ESP32', 'HC-SR04', 'Ultrason', 'OLED', 'Timing'],
  },
  {
    numero: 7,
    title: 'Minuterie et séquenceur',
    description: 'Minuterie réglable, séquenceur de LEDs et simulation de feux de circulation — la machine à états en pratique.',
    href: siteUrl('/ateliers/minuterie/'),
    level: 'intermediaire' as const,
    duration: '3h',
    tags: ['ESP32', 'Machine à états', 'LED', 'Temps réel', 'Boutons'],
  },
  {
    numero: 8,
    title: 'Badge RFID',
    description: 'Un lecteur RC522 identifie les badges. Accès accordé = LED verte. Badge inconnu = alarme sonore.',
    href: siteUrl('/ateliers/rfid/'),
    level: 'intermediaire' as const,
    duration: '3h',
    tags: ['ESP32', 'RFID', 'RC522', 'SPI', 'Sécurité'],
  },
];
---

<Layout
  title="Ateliers pratiques"
  description="8 ateliers MicroPython pour débutants en Ardèche. ESP32, NeoPixel, capteurs, RFID, son. Code sur GitHub, matériel fourni, 20€/3h."
>
  <section class="py-20 hero-pattern border-b border-base-200/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-primary text-sm font-mono font-medium mb-3">// ateliers</p>
        <h1 class="text-4xl sm:text-5xl font-black mb-5">Projets pratiques</h1>
        <p class="text-base-content/65 text-lg leading-relaxed">
          Des ateliers en présentiel en Ardèche pour créer de vrais projets avec l'ESP32 et MicroPython. Code disponible sur GitHub, schémas inclus.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <div class="inline-flex items-center gap-2 bg-base-200/60 rounded-full px-4 py-2 text-sm">
            <span class="w-2 h-2 rounded-full bg-success"></span>
            9 ateliers disponibles
          </div>
          <div class="inline-flex items-center gap-2 bg-base-200/60 rounded-full px-4 py-2 text-sm font-semibold">
            20€ / 3h · 6 personnes max
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {ateliers.map(atelier => (
          <AtelierCard {...atelier} />
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-base-200/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl font-black mb-4">Tout le matériel est fourni</h2>
        <p class="text-base-content/60 mb-8">
          ESP32, câbles, composants — tu n'as besoin que de ta curiosité. Tu repars avec le code sur GitHub et les schémas.
        </p>
        <a href={siteUrl('/a-propos/')} class="btn btn-primary gap-2">
          Réserver un atelier
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
