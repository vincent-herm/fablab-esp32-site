---
import Layout from '../../layouts/Layout.astro';
import { siteUrl } from '../../utils/url';

const boards = [
  { name: 'ESP32 classique', desc: 'La board originale — WiFi + Bluetooth, 38 GPIO', href: siteUrl('/doc/cartes/#esp32-classique'), badge: 'ESP32' },
  { name: 'ESP32-S3', desc: 'Version améliorée — plus de GPIO, USB natif', href: siteUrl('/doc/cartes/#esp32-s3'), badge: 'ESP32-S3' },
  { name: 'Waveshare Touch LCD 3.5"', desc: 'Écran tactile + codec audio + micro intégrés', href: siteUrl('/doc/cartes/#waveshare-touch-35'), badge: 'Audio' },
  { name: 'Raspberry Pi Pico 2W', desc: 'RP2350, WiFi, dual-core — MicroPython officiel', href: siteUrl('/doc/cartes/#pico-2w'), badge: 'Pico' },
  { name: 'M5Stack StickC Plus2', desc: 'Écran, batterie, boutons — tout-en-un', href: siteUrl('/doc/cartes/#m5stack'), badge: 'M5Stack' },
  { name: 'Waveshare Touch LCD', desc: 'Écrans tactiles pour ESP32-S3', href: siteUrl('/doc/cartes/#waveshare-s3'), badge: 'Display' },
];

const composants = [
  { name: 'DHT22', desc: 'Température et humidité', protocole: 'GPIO', href: siteUrl('/doc/composants/dht22/') },
  { name: 'HC-SR04', desc: 'Mesure de distance ultrason', protocole: 'GPIO', href: siteUrl('/doc/composants/hc-sr04/') },
  { name: 'MPU6050', desc: 'Accéléromètre + gyroscope', protocole: 'I2C', href: siteUrl('/doc/composants/mpu6050/') },
  { name: 'RC522', desc: 'Lecteur RFID', protocole: 'SPI', href: siteUrl('/doc/composants/rc522/') },
  { name: 'SSD1306', desc: 'Écran OLED 128×64', protocole: 'I2C', href: siteUrl('/doc/composants/ssd1306/') },
  { name: 'ES8388', desc: 'Codec audio stéréo', protocole: 'I2C+I2S', href: siteUrl('/doc/composants/es8388/') },
  { name: 'MAX7219', desc: 'Matrice LED 8×32 (1088AS)', protocole: 'SPI', href: siteUrl('/doc/composants/max7219/') },
];

const protocoleColors: Record<string, string> = {
  'GPIO': 'bg-blue-500/15 text-blue-400',
  'I2C': 'bg-purple-500/15 text-purple-400',
  'SPI': 'bg-orange-500/15 text-orange-400',
  'I2C+I2S': 'bg-pink-500/15 text-pink-400',
};
---

<Layout
  title="Documentation technique"
  description="Fiches de référence : ESP32, ESP32-S3, Pico 2W, M5Stack, Waveshare. Composants, brochages, code MicroPython."
>
  <section class="py-20 hero-pattern border-b border-base-200/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-emerald-400 text-sm font-mono font-medium mb-3">// documentation</p>
        <h1 class="text-4xl sm:text-5xl font-black mb-5">Documentation technique</h1>
        <p class="text-base-content/65 text-lg leading-relaxed">
          Fiches de référence pour les boards et composants utilisés dans les ateliers.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-black mb-8">Cartes de développement</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {boards.map(board => (
          <a href={board.href} class="group rounded-xl border border-base-200/80 bg-base-200/20 p-5 hover:border-emerald-500/30 hover:bg-base-200/40 transition-all block">
            <span class="text-xs font-mono font-bold text-emerald-400 bg-emerald-500/10 px-2.5 py-1 rounded-lg">{board.badge}</span>
            <h3 class="font-bold text-sm mt-3 mb-1 group-hover:text-emerald-400 transition-colors">{board.name}</h3>
            <p class="text-xs text-base-content/50">{board.desc}</p>
            <p class="text-xs text-emerald-400/60 mt-2 font-medium">Voir la fiche →</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-base-200/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-black mb-8">Outils</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-16">
        {[
          { name: 'Thonny', desc: 'IDE recommandé : connexion, REPL, transfert de fichiers, flash du firmware', href: siteUrl('/doc/thonny/'), badge: 'IDE' },
          { name: 'Commandes OS', desc: 'Gérer les fichiers sur l\'ESP32 : os.listdir(), boot.py, main.py, mémoire', href: siteUrl('/doc/micropython-os/'), badge: 'MicroPython' },
        ].map(tool => (
          <a href={tool.href} class="group rounded-xl border border-base-200/80 bg-base-200/20 p-5 hover:border-emerald-500/30 hover:bg-base-200/40 transition-all block">
            <span class="text-xs font-mono font-bold text-emerald-400 bg-emerald-500/10 px-2.5 py-1 rounded-lg">{tool.badge}</span>
            <h3 class="font-bold text-sm mt-3 mb-1 group-hover:text-emerald-400 transition-colors">{tool.name}</h3>
            <p class="text-xs text-base-content/50">{tool.desc}</p>
            <p class="text-xs text-emerald-400/60 mt-2 font-medium">Voir la fiche →</p>
          </a>
        ))}
      </div>
      <h2 class="text-2xl font-black mb-8">Composants</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {composants.map(comp => (
          comp.href ? (
            <a href={comp.href} class="group rounded-xl border border-base-200/80 bg-base-100/50 p-5 hover:border-emerald-500/30 hover:bg-base-200/40 transition-all block">
              <span class={`text-xs font-mono font-bold px-2.5 py-1 rounded-lg ${protocoleColors[comp.protocole]}`}>{comp.protocole}</span>
              <h3 class="font-bold text-sm mt-3 mb-1 font-mono group-hover:text-emerald-400 transition-colors">{comp.name}</h3>
              <p class="text-xs text-base-content/50">{comp.desc}</p>
              <p class="text-xs text-emerald-400/60 mt-2 font-medium">Voir la fiche →</p>
            </a>
          ) : (
            <div class="rounded-xl border border-base-200/80 bg-base-100/50 p-5">
              <span class={`text-xs font-mono font-bold px-2.5 py-1 rounded-lg ${protocoleColors[comp.protocole]}`}>{comp.protocole}</span>
              <h3 class="font-bold text-sm mt-3 mb-1 font-mono">{comp.name}</h3>
              <p class="text-xs text-base-content/50">{comp.desc}</p>
              <p class="text-xs text-base-content/30 mt-2 italic">Fiche à venir</p>
            </div>
          )
        ))}
      </div>
    </div>
  </section>
</Layout>
