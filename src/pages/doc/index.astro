---
import Layout from '../../layouts/Layout.astro';

const boards = [
  { name: 'ESP32 classique', desc: 'La board originale — WiFi + Bluetooth, 38 GPIO', href: '/doc/boards/esp32/', badge: 'ESP32' },
  { name: 'ESP32-S3', desc: 'Version améliorée — plus de GPIO, USB natif', href: '/doc/boards/esp32-s3/', badge: 'ESP32-S3' },
  { name: 'ESP32-A1S AudioKit', desc: 'Codec ES8388, micro, haut-parleurs, boutons', href: '/doc/boards/esp32-audiokit/', badge: 'Audio' },
  { name: 'Raspberry Pi Pico 2W', desc: 'RP2350, WiFi, dual-core — MicroPython officiel', href: '/doc/boards/pico-2w/', badge: 'Pico' },
  { name: 'M5Stack StickC Plus2', desc: 'Écran, batterie, boutons — tout-en-un', href: '/doc/boards/m5stack-stickc/', badge: 'M5Stack' },
  { name: 'Waveshare Touch LCD', desc: 'Écrans tactiles ronds et rectangulaires pour ESP32-S3', href: '/doc/boards/waveshare-touch-lcd/', badge: 'Display' },
];

const composants = [
  { name: 'DHT22', desc: 'Température et humidité', protocole: 'GPIO', href: '/doc/composants/dht22/' },
  { name: 'HC-SR04', desc: 'Mesure de distance ultrason', protocole: 'GPIO', href: '/doc/composants/hc-sr04/' },
  { name: 'MPU6050', desc: 'Accéléromètre + gyroscope', protocole: 'I2C', href: '/doc/composants/mpu6050/' },
  { name: 'RC522', desc: 'Lecteur RFID', protocole: 'SPI', href: '/doc/composants/rc522/' },
  { name: 'SSD1306', desc: 'Écran OLED 128×64', protocole: 'I2C', href: '/doc/composants/ssd1306/' },
  { name: 'ES8388', desc: 'Codec audio stéréo', protocole: 'I2C+I2S', href: '/doc/composants/es8388/' },
];

const protocoleColors: Record<string, string> = {
  'GPIO': 'bg-blue-500/15 text-blue-400',
  'I2C': 'bg-purple-500/15 text-purple-400',
  'SPI': 'bg-orange-500/15 text-orange-400',
  'I2C+I2S': 'bg-pink-500/15 text-pink-400',
};
---

<Layout
  title="Documentation technique"
  description="Fiches de référence : ESP32, ESP32-S3, Pico 2W, M5Stack, Waveshare. Composants, brochages, code MicroPython."
>
  <!-- En-tête -->
  <section class="py-20 hero-pattern border-b border-base-200/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-emerald-400 text-sm font-mono font-medium mb-3">// documentation</p>
        <h1 class="text-4xl sm:text-5xl font-black mb-5">Documentation technique</h1>
        <p class="text-base-content/65 text-lg leading-relaxed">
          Fiches de référence pour les boards et composants utilisés dans les ateliers. Brochages, exemples de code, liens d'achat.
        </p>
      </div>
    </div>
  </section>

  <!-- Boards -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-8">
        <h2 class="text-2xl font-black">Cartes de développement</h2>
        <a href="/doc/boards/" class="text-sm text-base-content/50 hover:text-primary transition-colors ml-auto">
          Toutes les boards →
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {boards.map(board => (
          <a href={board.href} class="group rounded-xl border border-base-200/80 bg-base-200/20 p-5 card-hover hover:border-emerald-500/30 transition-colors">
            <div class="flex items-start justify-between mb-3">
              <span class="text-xs font-mono font-bold text-emerald-400 bg-emerald-500/10 px-2.5 py-1 rounded-lg">
                {board.badge}
              </span>
              <svg class="w-4 h-4 text-base-content/30 group-hover:text-emerald-400 group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
            <h3 class="font-bold text-sm mb-1 group-hover:text-emerald-400 transition-colors">{board.name}</h3>
            <p class="text-xs text-base-content/50">{board.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Composants -->
  <section class="py-16 bg-base-200/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-8">
        <h2 class="text-2xl font-black">Composants</h2>
        <a href="/doc/composants/" class="text-sm text-base-content/50 hover:text-primary transition-colors ml-auto">
          Tous les composants →
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {composants.map(comp => (
          <a href={comp.href} class="group rounded-xl border border-base-200/80 bg-base-100/50 p-5 card-hover hover:border-primary/30 transition-colors">
            <div class="flex items-start justify-between mb-3">
              <span class={`text-xs font-mono font-bold px-2.5 py-1 rounded-lg ${protocoleColors[comp.protocole]}`}>
                {comp.protocole}
              </span>
            </div>
            <h3 class="font-bold text-sm mb-1 font-mono group-hover:text-primary transition-colors">{comp.name}</h3>
            <p class="text-xs text-base-content/50">{comp.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
